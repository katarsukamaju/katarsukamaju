# =========================================================================
# KONFIGURASI LINGKUNGAN (ENVIRONMENT VARIABLES) - LANDING PAGE REACT JS
# =========================================================================
# Catatan: Karena proyek ini menggunakan Create React App (react-scripts),
# semua variabel khusus aplikasi harus diawali dengan prefix "REACT_APP_".
# Setelah mengubah file ini, Anda harus ME-RESTART server pengembangan (npm start).
# =========================================================================

# -------------------------------------------------------------------------
# 1. INFORMASI UMUM & METADATA APLIKASI
# -------------------------------------------------------------------------
REACT_APP_NAME="Katar Sukamaju"
REACT_APP_DESCRIPTION="Landing Page Karang Taruna Desa Sukamaju"
REACT_APP_URL="https://katarsukamaju.com"
REACT_APP_VERSION="1.0.0"

# -------------------------------------------------------------------------
# 2. KONFIGURASI API UTAMA (BACKEND)
# -------------------------------------------------------------------------
# URL endpoint backend utama jika landing page mengambil data dinamis
REACT_APP_API_URL="http://localhost:5000/api"

# -------------------------------------------------------------------------
# 3. ANALYTICS & MONITORING (Sangat penting untuk Landing Page)
# -------------------------------------------------------------------------
# Google Analytics 4 (GA4)
REACT_APP_GA_MEASUREMENT_ID="G-XXXXXXXXXX"

# Mixpanel (Pelacakan Event)
REACT_APP_MIXPANEL_TOKEN="your_mixpanel_project_token_here"

# Hotjar (Heatmap & Rekaman User)
REACT_APP_HOTJAR_ID="your_hotjar_site_id"
REACT_APP_HOTJAR_SV="6"

# -------------------------------------------------------------------------
# 4. EMAIL, HUBUNGI KAMI & FORMS (Untuk formulir kontak / newsletter)
# -------------------------------------------------------------------------
# EmailJS (Mengirim email langsung dari React tanpa backend sendiri)
REACT_APP_EMAILJS_SERVICE_ID="service_xxxxxxx"
REACT_APP_EMAILJS_TEMPLATE_ID="template_xxxxxxx"
REACT_APP_EMAILJS_PUBLIC_KEY="your_public_key_here"

# Formspree (Alternatif pengiriman form kontak)
REACT_APP_FORMSPREE_HASH_ID="your_formspree_hash_id"

# Mailchimp (Untuk Newsletter/Langganan)
REACT_APP_MAILCHIMP_U="your_mailchimp_u_value"
REACT_APP_MAILCHIMP_ID="your_mailchimp_id"

# -------------------------------------------------------------------------
# 5. CHAT DUKUNGAN / LIVE CHAT
# -------------------------------------------------------------------------
# Crisp Chat
REACT_APP_CRISP_WEBSITE_ID="your-crisp-website-id-here"

# Tawk.to Chat
REACT_APP_TAWKTO_PROPERTY_ID="your-tawkto-property-id"
REACT_APP_TAWKTO_WIDGET_ID="your-tawkto-widget-id"

# -------------------------------------------------------------------------
# 6. INTEGRASI BACKEND SEBAGAI LAYANAN (BaaS) - Jika ada login/database/waitlist
# -------------------------------------------------------------------------
# Supabase
REACT_APP_SUPABASE_URL="https://your-project-id.supabase.co"
REACT_APP_SUPABASE_ANON_KEY="your-anon-key-here"

# Firebase (Alternatif BaaS)
REACT_APP_FIREBASE_API_KEY="your-firebase-api-key"
REACT_APP_FIREBASE_AUTH_DOMAIN="your-app.firebaseapp.com"
REACT_APP_FIREBASE_PROJECT_ID="your-app-id"
REACT_APP_FIREBASE_STORAGE_BUCKET="your-app.appspot.com"
REACT_APP_FIREBASE_MESSAGING_SENDER_ID="your-sender-id"
REACT_APP_FIREBASE_APP_ID="your-app-id"

# -------------------------------------------------------------------------
# 7. KONFIGURASI HUBUNGI & SOSIAL MEDIA (Agar dinamis di dalam UI)
# -------------------------------------------------------------------------
REACT_APP_CONTACT_EMAIL="info@katarsukamaju.com"
REACT_APP_CONTACT_PHONE="+6281234567890"
REACT_APP_WHATSAPP_NUMBER="6281234567890"
REACT_APP_WHATSAPP_DEFAULT_TEXT="Halo Katar Sukamaju, saya ingin bertanya..."

# Tautan Sosial Media
REACT_APP_INSTAGRAM_URL="https://instagram.com/katarsukamaju"
REACT_APP_FACEBOOK_URL="https://facebook.com/katarsukamaju"
REACT_APP_TWITTER_URL="https://twitter.com/katarsukamaju"
REACT_APP_LINKEDIN_URL="https://linkedin.com/company/katarsukamaju"

# -------------------------------------------------------------------------
# 8. LAYANAN PETA (Google Maps / Mapbox)
# -------------------------------------------------------------------------
REACT_APP_GOOGLE_MAPS_API_KEY="your-google-maps-api-key"
REACT_APP_MAPBOX_ACCESS_TOKEN="your-mapbox-access-token"

# -------------------------------------------------------------------------
# 9. INTEGRASI API SENSITIF (PERINGATAN KEAMANAN: Kunci di bawah ini akan terekspos di browser)
# -------------------------------------------------------------------------
# Google AI Studio (Gemini API)
REACT_APP_GEMINI_API_KEY="your-google-ai-studio-api-key-here"

# GitHub Personal Access Token (PAT) - Contoh: untuk fetch repository/profile data
REACT_APP_GITHUB_PAT="your-github-personal-access-token-here"
